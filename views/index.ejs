<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %> | Abdul Rehman Ishaque Portfolio</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <!-- Navbar -->
  <nav>
    <div class="navbar">
      <a href="#home">
        <!-- Profile logo: use any image from /public/images/ or avatar -->
        <img src="/images/ChatGPT Image Aug 30, 2025, 07_50_40 PM.png" class="nav-logo" alt="Profile Logo">
      </a>
      <ul class="menu">
        <li><a href="#home">Home</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <div class="media-icons">
        <a href="https://github.com/abdulrehman" target="_blank" title="GitHub"><i class="fab fa-github"></i></a>
        <a href="https://linkedin.com/in/abdulrehmanishaque" target="_blank" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
        <a href="mailto:abdulrehman@example.com" title="Email"><i class="fas fa-envelope"></i></a>
      </div>
    </div>
  </nav>

  <!-- Home Section -->
  <section class="home" id="home">
    <div class="home-content">
      <div class="profile-img">
        <img src="/images/ChatGPT Image Aug 30, 2025, 07_50_40 PM.png" alt="Abdul Rehman Ishaque">
      </div>
      <div class="text-one">Hello, I'm</div>
      <div class="text-two">Abdul Rehman Ishaque</div>
      <div class="text-three">Full Stack Software Engineer</div>
      <p>
        Passionate builder of web applications, elegant user experiences, and robust backend systems.
        <br>
        <a href="/docs/Abdul_Rehman_Ishaque_CV.docx" class="services view" target="_blank"><i class="fas fa-download"></i> Download CV</a>
      </p>
      <div class="social-icons">
        <a href="https://github.com/abdulrehman" target="_blank"><i class="fab fa-github"></i></a>
        <a href="https://linkedin.com/in/abdulrehmanishaque" target="_blank"><i class="fab fa-linkedin"></i></a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about" id="about">
    <div class="about-details">
      <div class="left">
        <img src="/images/Screenshot 2025-08-07 160359.png" alt="Profile About">
      </div>
      <div class="right">
        <div class="topic">About Me</div>
        <p>
          <strong>Innovator, Engineer, Creator.</strong> 
          <br>
          I specialize in designing elegant web interfaces and architecting scalable backend systems. With a background in modern JavaScript, Node.js, React, and cloud technologies, I turn ideas into deployable solutions. My mission is to craft products that delight users and solve real-world problems.
        </p>
        <button onclick="window.location='#contact'">Let's Connect!</button>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="skills" id="skills">
    <div class="skills-details">
      <div class="text">
        <div class="topic">Skills & Technologies</div>
        <ul class="skillset">
          <li><strong>Languages:</strong> TypeScript, JavaScript, Python, C++</li>
          <li><strong>Frontend:</strong> React, Redux, HTML5, CSS3, SASS</li>
          <li><strong>Backend:</strong> Node.js, Express, REST APIs, GraphQL</li>
          <li><strong>DevOps:</strong> Docker, CI/CD, AWS, Vercel</li>
          <li><strong>Database:</strong> MongoDB, PostgreSQL, Redis</li>
          <li><strong>Testing:</strong> Jest, Mocha, Cypress</li>
          <li><strong>Other:</strong> Git, Scrum, Figma, EJS, Next.js</li>
        </ul>
      </div>
      <div class="boxes">
        <div class="box">
          <div class="topic">Web Development</div>
          <div class="per">Expert</div>
        </div>
        <div class="box">
          <div class="topic">Cloud & DevOps</div>
          <div class="per">Advanced</div>
        </div>
        <div class="box">
          <div class="topic">UI/UX Design</div>
          <div class="per">Intermediate</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="projects" id="projects">
    <div class="skills-details">
      <div class="text">
        <div class="topic">Featured Projects</div>
        <ul class="skillset">
          <li>
            <strong>Weather Dashboard:</strong>
            <br>
            <img src="/images/weather.png" alt="Weather App" style="width:80px;height:40px;vertical-align:middle;"> Real-time weather tracker built with React & OpenWeatherMap API.
          </li>
          <li>
            <strong>Calculator App:</strong>
            <br>
            <img src="/images/calculator.png" alt="Calculator" style="width:80px;height:40px;vertical-align:middle;"> Elegant calculator UI leveraging modern JS.
          </li>
          <li>
            <strong>AI Article Summarizer:</strong>
            <br>
            <img src="/images/101124.PR_.Toward-Effective1.webp" alt="AI Article" style="width:80px;height:40px;vertical-align:middle;"> GPT-powered article summarization tool.
          </li>
        </ul>
        <p>
          <a href="/projects" class="services view">View All Projects</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services" id="services">
    <div class="boxes">
      <div class="box">
        <div class="icon"><i class="fas fa-code"></i></div>
        <div class="topic">Web App Development</div>
        <p>Custom web applications from design to deployment, using React, Node.js, Express.</p>
      </div>
      <div class="box">
        <div class="icon"><i class="fas fa-cloud"></i></div>
        <div class="topic">Cloud Solutions</div>
        <p>Scalable cloud architecture, CI/CD pipelines, Docker containers, and AWS deployments.</p>
      </div>
      <div class="box">
        <div class="icon"><i class="fas fa-pencil-ruler"></i></div>
        <div class="topic">UI/UX Consulting</div>
        <p>Modern, accessible, engaging user experiences crafted with Figma and SASS.</p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact" id="contact">
    <div class="contact-form">
      <h2>Contact Me</h2>
      <form action="mailto:abdulrehman@example.com" method="post" enctype="text/plain">
        <input type="text" name="name" placeholder="Your Name" required>
        <input type="email" name="email" placeholder="Your Email" required>
        <textarea name="message" placeholder="Your Message" rows="5" required></textarea>
        <button type="submit">Send Message</button>
      </form>
    </div>
    <div class="message">
      Let's build something amazing together! Reach out for collaborations or freelance work.
    </div>
  </section>

  <!-- Footer -->
  <footer class="portfolio-footer">
    <div class="footer-container">
      <div class="footer-content">
        <div class="footer-section about">
          <h3>About</h3>
          <p>Abdul Rehman Ishaque | Portfolio v1<br>Built with Node.js, Express, EJS</p>
        </div>
        <div class="footer-section links">
          <h3>Quick Links</h3>
          <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#services">Services</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-section contact">
          <h3>Contact</h3>
          <ul>
            <li><i class="fas fa-envelope"></i> <a href="mailto:abdulrehman@example.com">abdulrehman@example.com</a></li>
            <li><i class="fas fa-phone"></i> +92 312 3456789</li>
            <li><i class="fas fa-map-marker-alt"></i> Lahore, Pakistan</li>
          </ul>
          <div class="social-icons">
            <a href="https://github.com/abdulrehman" target="_blank"><i class="fab fa-github"></i></a>
            <a href="https://linkedin.com/in/abdulrehmanishaque" target="_blank"><i class="fab fa-linkedin"></i></a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; <%= new Date().getFullYear() %> Abdul Rehman Ishaque. All Rights Reserved.
      </div>
    </div>
  </footer>
</body>
</html>
