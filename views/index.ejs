<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
  <meta charset="UTF-8" />
  <title>Responsive Portfolio | Abdul Rehman</title>
  <!-- Modern professional fonts -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Poppins:400,500,600,700&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Roboto:400,500,700&display=swap">
  <link rel="stylesheet" href="/stylesheets/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body>
  <!-- Move to up button -->
  <div class="scroll-button">
    <a href="#home"><i class="fas fa-arrow-up"></i></a>
  </div>

  <!-- Navbar -->
  <nav>
    <div class="navbar">
      <div class="logo">
        <a href="#">
          <img src="\images\ChatGPT Image Sep 3, 2025, 05_55_06 PM.png" alt="CodeCraft Logo" class="nav-logo">
        </a>
      </div>
      <ul class="menu">
        <li><a href="#home">Home</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#contact">Contact</a></li>
        <div class="cancel-btn"><i class="fas fa-times"></i></div>
      </ul>
      <div class="media-icons">
        <a href="mailto:abdulrehmanishaque32@gmail.com"><i class="fas fa-envelope"></i></a>
        <a href="https://wa.me/923009547799"><i class="fab fa-whatsapp"></i></a>
        <div class="menu-btn"><i class="fas fa-bars"></i></div>
      </div>
    </div>
  </nav>

  <!-- Home, About, Skills, Services -->
  <!-- ... (Other unchanged sections) ... -->

  <!-- Contact Section -->
  <div class="content" id="contact">
    <div class="title"><span>Contact Me</span></div>
    <% if (typeof sstatus !== 'undefined' && sstatus === 0) { %>
      <div class="contact-form">
        <form action="/contact" method="POST">
          <h2>Send Me a Message</h2>
          <input type="text" name="name" placeholder="Your Name" required />
          <input type="email" name="email" placeholder="Your Email" required />
          <textarea name="message" placeholder="Your Message" required></textarea>
          <button type="submit">Send</button>
        </form>
      </div>
    <% } else if (typeof sstatus !== 'undefined' && sstatus === 1) { %>
      <div class="thank-you">
        <h2>Thank you for contacting me<% if (typeof name !== 'undefined') { %>, <%= name %><% } %>!</h2>
        <p>I will get back to you at <%= typeof email !== 'undefined' ? email : 'your email' %>.</p>
      </div>
    <% } %>
  </div>

  <!-- Footer, etc. -->
  <script src="/javascripts/script.js"></script>
</body>
</html>
