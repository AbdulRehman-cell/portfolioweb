# .env.example for portfolioweb Express.js app

# Application environment
NODE_ENV=production            # 'development' or 'production'

# Server port (Render uses 3000 by default)
PORT=3000                     # Port Express listens on

# Email sending configuration
MAIL_HOST=smtp.example.com    # SMTP host for nodemailer
MAIL_PORT=587                 # SMTP port (usually 587 for TLS)
MAIL_USER=your_email@example.com   # SMTP username/email
MAIL_PASS=your-email-password      # SMTP password

# Optional: If you use secure SMTP connections
MAIL_SECURE=false             # 'true' for port 465, 'false' for 587

# Add any other secrets or configs as needed