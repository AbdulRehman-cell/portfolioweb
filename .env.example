# .env.example for portfolioweb

# Node environment
NODE_ENV=production

# SMTP credentials for email (required if using nodemailer)
SMTP_USER=your_smtp_username      # Required: Your SMTP username
SMTP_PASS=your_smtp_password      # Required: Your SMTP password

# Custom port (optional, default 3000)
PORT=3000                        # Optional: Port for Express app

# Add other needed environment variables below