```plaintext
# Environment variables for the application
# PORT represents the port the application will run on
PORT=3000

# NODE_ENV sets the environment mode
NODE_ENV=production

# Add your database connection string for any services here
# DATABASE_URL=postgres://example:password@localhost:5432/mydb

# Optional: Redis URL if Redis is used
# REDIS_URL=redis://localhost:6379

# Email server configuration for Nodemailer
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
```