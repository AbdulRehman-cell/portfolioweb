# .env.example
# Copy this to .env and update values for production deployment

# Port your Express server listens on
PORT=3000

# Node environment
NODE_ENV=production

# Email sender settings (required for contact forms etc)
# SMTP host, port, user, password
SMTP_HOST=smtp.example.com        # e.g. smtp.gmail.com
SMTP_PORT=587                    # e.g. 465, 587
SMTP_USER=your-email@example.com
SMTP_PASS=super-secret-password

# Add any other environment variables your app needs below