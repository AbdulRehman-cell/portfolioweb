# Example .env file for PortfolioWeb

# -------- Core Environment Variables --------
NODE_ENV=production    # Set to 'production' for Render

# -------- Mail (Nodemailer) --------
SMTP_HOST=smtp.example.com     # SMTP server address
SMTP_PORT=587                  # SMTP port (typically 587 for TLS)
SMTP_USER=your@email.com       # SMTP username
SMTP_PASS=yourSecretPassword   # SMTP password

# -------- Optional --------
PORT=3000                     # Web server port (Render sets automatically)
DEBUG=portfolioweb:*          # Debug module pattern for logging