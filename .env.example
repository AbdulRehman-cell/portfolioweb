# Express App Env Vars

NODE_ENV=production        # "production" for deployed app
PORT=3000                  # Port app listens on (Render defaults to 3000)

# Email Sending (Nodemailer)
SMTP_HOST=your-smtp-host   # e.g., smtp.gmail.com
SMTP_PORT=587              # e.g., 587
SMTP_USER=your-email       # e.g., noreply@yourdomain.com
SMTP_PASS=your-password    # e.g., app-specific password

# You can add more variables as the app needs (e.g., API_KEYS, SESSION_SECRET)

# SESSION_SECRET=your-session-secret