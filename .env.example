# Example environment variables for portfolioweb

# Node environment (production, development, etc.)
NODE_ENV=production

# Port for web server (default: 3000)
PORT=3000

# Email settings (if used in nodemailer)
EMAIL_USER=your_email_username_here   # Username for sending emails
EMAIL_PASS=your_email_password_here   # Password for sending emails

# Any other environment variables needed by your code
# Example: DB_CONNECTION=your_db_connection_string