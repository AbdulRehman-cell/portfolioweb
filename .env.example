# --- Example environment variables ---
# copy to .env and fill out values for production/local

# App PORT
PORT=3000  # Port the app listens on, default 3000

# Application secret keys
COOKIE_SECRET=your-secret-key  # For cookie-parser

# Email configuration (Nodemailer)
SMTP_HOST=smtp.example.com  # SMTP server host
SMTP_PORT=587               # SMTP port (e.g. 587 for TLS, 465 for SSL)
SMTP_USER=your-email@example.com  # SMTP auth username
SMTP_PASS=your-email-password     # SMTP auth password

# Miscellaneous
NODE_ENV=production  # Can be set to development for local